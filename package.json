{
  "name": "ghd",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "electrobun dev",
    "dev:watch": "electrobun dev --watch",
    "start": "electrobun run",
    "build": "electrobun build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "typecheck": "bash scripts/typecheck.sh",
    "test": "bun test",
    "test:unit": "bun test tests/",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "electrobun": "1.15.1",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/bun": "1.3.10",
    "lefthook": "2.1.3",
    "typescript": "5.9.3"
  }
}
